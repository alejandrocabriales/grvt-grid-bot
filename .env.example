# ──────────────────────────────────────────────────────────────────────────────
# GRVT Grid Bot — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env a un repositorio.
# ──────────────────────────────────────────────────────────────────────────────

# Tu API Key de GRVT (obtenida desde la UI de GRVT → Settings → API Keys)
GRVT_API_KEY=

# La clave privada de la wallet que firmará las órdenes via EIP-712.
# IMPORTANTE: Debe ser la wallet que vinculaste como "Signer Address" en GRVT UI.
# Formato: string hexadecimal de 64 chars, con o sin prefijo 0x
GRVT_PRIVATE_KEY_EIP712=0x

# Tu Sub Account ID numérico (visible en la URL de GRVT tras iniciar sesión)
GRVT_SUB_ACCOUNT_ID=

# true = usar testnet de GRVT (trades.testnet.grvt.io)
# false = mainnet real (trades.grvt.io)
GRVT_USE_TESTNET=false
# Duplicate for client-side access (Next.js requires NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_GRVT_USE_TESTNET=false
